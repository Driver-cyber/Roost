# Roost — Environment Variables
#
# Copy this file to `.env` for local development (gitignored).
# In production, these are set in Cloudflare Pages → Settings →
# Environment variables.
#
# IMPORTANT: Do not commit a real `.env` file. Only commit this
# `.env.example` with empty values.

# ---------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------
# From Supabase dashboard → Project Settings → API.
# The anon key is safe to expose client-side (row-level security
# protects the data), but we env it for cleanliness and to make
# environment swaps easy.

SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------
# eBird API
# ---------------------------------------------------------------------
# Request a key at https://ebird.org/api/keygen
# Tied to a Cornell Lab account — ideally a shared household account
# so Joelle's Merlin sightings flow through the same identity.

EBIRD_API_KEY=

# ---------------------------------------------------------------------
# PMTiles
# ---------------------------------------------------------------------
# Public URL of the .pmtiles file in Cloudflare R2.
# Format typically: https://pub-<hash>.r2.dev/roost-neighborhood.pmtiles
# Or your custom domain if you've set one up.

PMTILES_URL=

# ---------------------------------------------------------------------
# Home anchor
# ---------------------------------------------------------------------
# Coordinates for the home pin and yard outline on the map.
# Not secret, but environment-specific (dev vs prod could differ if
# we ever stage a fake neighborhood for testing).
# Decimal degrees. Negative longitude for western hemisphere.

HOME_LAT=
HOME_LON=

# ---------------------------------------------------------------------
# eBird query parameters
# ---------------------------------------------------------------------
# Radius (km) around home for the eBird "recent nearby observations"
# call. eBird API caps this at 50 km. Default 5 km feels neighborhood-
# scaled; bump up if the ambient layer feels too quiet.

EBIRD_RADIUS_KM=5

# Number of days back for ambient eBird data. Max 30. Lower number =
# fresher feel, fewer pins. Higher = more populated map.

EBIRD_DAYS_BACK=7
